#################################################################
#    General axioms
#################################################################

[ rdf:type owl:Restriction ;
  owl:onProperty dul:hasParticipant ;
  owl:someValuesFrom rope:TrainRun ;
  rdfs:subClassOf rope:TrainRunState
] .


[ rdf:type owl:Restriction ;
  owl:onProperty dul:hasSetting ;
  owl:someValuesFrom rope:StaticSection ;
  rdfs:subClassOf rope:TrainService
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( rope:Container
                rope:SwapBody
                rope:Trailer
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( rope:Facility
                rope:Load
                rope:Track
                rope:Train
                rope:Wagon
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( rope:ITU
                rope:TrainRun
                rope:Wagon
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( rope:LoadRole
                rope:OperationalArtifact
                rope:OperationalLocation
                rope:OperationalProcess
                rope:OperationalRole
                rope:OperationalState
                rope:TractionProvisionRole
                rope:VersionedDescription
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( rope:Path
                rope:PlannedJourney
                rope:UndeterminedJourney
              )
] .


