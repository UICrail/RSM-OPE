@prefix : <http://cdm.ovh/rsm/operations/rope/rope#> .
@prefix bag: <http://www.ontologydesignpatterns.org/cp/owl/bag.owl#> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix list: <http://www.ontologydesignpatterns.org/cp/owl/list.owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rope: <https://cdm.ovh/rsm/operations/rope/rope#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix regorg: <http://www.w3.org/ns/regorg#> .
@prefix rst-cons: <https://cdm.ovh/rst/cons/cons#> .
@prefix rst-typo: <https://cdm.ovh/rst/typo/typo#> .
@base <http://cdm.ovh/rsm/operations/rope/rope#> .

<http://cdm.ovh/rsm/operations/rope/rope> rdf:type owl:Ontology ;
                                           owl:versionIRI <http://cdm.ovh/rsm/operations/rope/0.1/rope> ;
                                           owl:imports <http://cdm.ovh/rst/cons/cons> ,
                                                       <https://cdm.ovh/rsm/network/netw> ;
                                           rdfs:comment "In the context of operations in general, and the TAF TSI in particular, \"weight\"  is often used instead of \"mass\" while the latter is correct (and units are indeed mass units, e.g. kg). In the present ontology, we only use \"mass\"  in identifiers and labels."@en ;
                                           owl:priorVersion "was tafp5 (deprecated)"@en ;
                                           owl:versionInfo "0.1 First release as ROPE (RSM Operations)"@en .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2000/01/rdf-schema#Literal
rdfs:Literal rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#base64Binary
xsd:base64Binary rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#boolean
xsd:boolean rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype ;
         rdfs:comment "Not part of OWL2 datatype map. Will crash HermiT, not however Pellet."@en .


###  http://www.w3.org/2001/XMLSchema#dateTimeStamp
xsd:dateTimeStamp rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#decimal
xsd:decimal rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#string
xsd:string rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.ontologydesignpatterns.org/cp/owl/bag.owl#hasItem
bag:hasItem rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/cp/owl/list.owl#nextItem
list:nextItem rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/cp/owl/list.owl#previousItem
list:previousItem rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasLocation
dul:hasLocation rdf:type owl:ObjectProperty ;
                rdfs:comment "To be understood as \"at some point in time\". Which point (or interval) will be given by the States."@en .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart
dul:hasPart rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant
dul:hasParticipant rdf:type owl:ObjectProperty ;
                   rdfs:comment "indicates participant in the process (no defined multiplicity)"@en .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting
dul:hasSetting rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasTimeInterval
dul:hasTimeInterval rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy
dul:isClassifiedBy rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isLocationOf
dul:isLocationOf rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor
dul:isSettingFor rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#playsRole
dul:playsRole rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizes
dul:realizes rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasAttributedTo
prov:wasAttributedTo rdf:type owl:ObjectProperty ;
                     rdfs:domain prov:Entity .


###  http://www.w3.org/ns/prov#wasRevisionOf
prov:wasRevisionOf rdf:type owl:ObjectProperty .


###  https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation
rope:atOperationalLocation rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf dul:hasLocation ;
                           owl:inverseOf rope:isOperationalLocationOf ;
                           rdfs:range rope:OperationalLocation ;
                           rdfs:comment "provides time-independent operational location of anything, including bit not limited toTracks or Facilities (both being NetEntities), or TrainRuns."@en ;
                           rdfs:label "at operational location"^^xsd:language .


###  https://cdm.ovh/rsm/operations/rope/rope#hasTrain
rope:hasTrain rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf dul:hasParticipant ;
              rdfs:domain rope:Circulation ;
              rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#Train> ;
              rdfs:comment "refers to the train (rolling stock, supplies, loads) that participates in the operational process."@en ;
              rdfs:label "has train"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#isOperationalLocationOf
rope:isOperationalLocationOf rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf dul:isLocationOf ;
                             rdfs:comment "inverse property of atOperationalLocation."@en ;
                             rdfs:label "is operational location of"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#atTime
<https://cdm.ovh/rsm/operations/rope/rope#atTime> rdf:type owl:ObjectProperty ;
                                   rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalTime> ;
                                   rdfs:label "at time"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasArrivalTime
<https://cdm.ovh/rsm/operations/rope/rope#hasArrivalTime> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                           rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant> ;
                                           rdfs:label "has arrival time"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasBeginning
<https://cdm.ovh/rsm/operations/rope/rope#hasBeginning> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf time:hasBeginning ;
                                         rdf:type owl:FunctionalProperty ;
                                         rdfs:label "has beginning"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasComposition
<https://cdm.ovh/rsm/operations/rope/rope#hasComposition> rdf:type owl:ObjectProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState> ;
                                           rdfs:range <http://cdm.ovh/rsm/rolling_stock/typology/typology#RollingStock> ;
                                           rdfs:label "has composition"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasCustomsStatus
<https://cdm.ovh/rsm/operations/rope/rope#hasCustomsStatus> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState> ;
                                             rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus> ;
                                             rdfs:label "has customs status"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasDepartureTime
<https://cdm.ovh/rsm/operations/rope/rope#hasDepartureTime> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                             rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant> ;
                                             rdfs:comment "May have multiple values (e.g. planned, revised, forecast, actual...), hence NOT a functional property"@en ;
                                             rdfs:label "has departure time"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasDestination
<https://cdm.ovh/rsm/operations/rope/rope#hasDestination> rdf:type owl:ObjectProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                           rdfs:range rope:OperationalLocation ;
                                           rdfs:label "has destination"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasEnd
<https://cdm.ovh/rsm/operations/rope/rope#hasEnd> rdf:type owl:ObjectProperty ;
                                   rdfs:subPropertyOf time:hasEnd ;
                                   rdf:type owl:FunctionalProperty ;
                                   rdfs:label "has end"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasFacilityFunction
<https://cdm.ovh/rsm/operations/rope/rope#hasFacilityFunction> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf dul:isClassifiedBy ;
                                                rdfs:domain rope:Facility ;
                                                rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction> ;
                                                rdfs:label "has facility function"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasIM
<https://cdm.ovh/rsm/operations/rope/rope#hasIM> rdf:type owl:ObjectProperty ;
                                  rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                  rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder> ;
                                  rdfs:label "has IM"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasImageContent
<https://cdm.ovh/rsm/operations/rope/rope#hasImageContent> rdf:type owl:ObjectProperty ,
                                                     owl:InverseFunctionalProperty ;
                                            rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Image> ;
                                            rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#ContentLocation> ;
                                            rdfs:label "has image content"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasJourney
<https://cdm.ovh/rsm/operations/rope/rope#hasJourney> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState> ;
                                       rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#Journey> ;
                                       rdfs:comment "not a functional property, as it can be expressed w.r.t. the planned journey or the executed journey (if available). User feedback welcome."@en ;
                                       rdfs:label "has journey" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasJourneySchedule
<https://cdm.ovh/rsm/operations/rope/rope#hasJourneySchedule> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Journey> ;
                                               rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                               rdfs:comment "Note: it may be that the same path or planned journey has multiple schedules (variants), not further characterized here, so we did not make this property functional."@en ;
                                               rdfs:label "has journey schedule" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOTN
<https://cdm.ovh/rsm/operations/rope/rope#hasOTN> rdf:type owl:ObjectProperty ;
                                   rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                   rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OTN> ;
                                   rdfs:comment "The same train run can have different Operational Train Numbers in its course, depending on the operator or network over which it is run."@en ;
                                   rdfs:label "has OTN"@en ;
                                   rdfs:seeAlso "http://data.europa.eu/949/hasOperationalTrainNumberIdentifier"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInstant
<https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInstant> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                                  rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant> ;
                                                  rdfs:label "has operational instant"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInterval
<https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInterval> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                                   rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval> ;
                                                   rdfs:label "has operational interval"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOperationalLocation
<https://cdm.ovh/rsm/operations/rope/rope#hasOperationalLocation> rdf:type owl:ObjectProperty ,
                                                            owl:FunctionalProperty ;
                                                   rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#StaticSection> ;
                                                   rdfs:range rope:OperationalLocation ;
                                                   rdfs:label "has operational location"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOrigin
<https://cdm.ovh/rsm/operations/rope/rope#hasOrigin> rdf:type owl:ObjectProperty ,
                                               owl:FunctionalProperty ;
                                      rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                      rdfs:range rope:OperationalLocation ;
                                      rdfs:label "has origin"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasParticipant
<https://cdm.ovh/rsm/operations/rope/rope#hasParticipant> rdf:type owl:ObjectProperty ;
                                           rdfs:label "has participant"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasPayload
<https://cdm.ovh/rsm/operations/rope/rope#hasPayload> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                       rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                       rdfs:label "has payload"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasPlannedJourney
<https://cdm.ovh/rsm/operations/rope/rope#hasPlannedJourney> rdf:type owl:ObjectProperty ,
                                                       owl:FunctionalProperty ;
                                              rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                              rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> ;
                                              rdfs:label "has planned journey"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasRU
<https://cdm.ovh/rsm/operations/rope/rope#hasRU> rdf:type owl:ObjectProperty ;
                                  rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                  rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder> ;
                                  rdfs:comment """RU responsible for the journey section.
The Lead RU (responsible for the train run also for the commercial aspects) is defined at train run level."""@en ;
                                  rdfs:label "has RU"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasReferenceObject
<https://cdm.ovh/rsm/operations/rope/rope#hasReferenceObject> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                               rdfs:range [ rdf:type owl:Class ;
                                                            owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                          <https://cdm.ovh/rsm/operations/rope/rope#TrainRun>
                                                                          <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                        )
                                                          ] ;
                                               rdfs:comment "following the data requirements, this property qualifies the message. However this may not be optimal, since Operational States \"know\" about the objects concerned, via dul:hasSetting or dul:hasParticipant."@en ;
                                               rdfs:label "has reference object" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasResult
<https://cdm.ovh/rsm/operations/rope/rope#hasResult> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainServicingState> ;
                                      rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#TrainServicingResult> ;
                                      rdfs:label "has result"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasSchedulePart
<https://cdm.ovh/rsm/operations/rope/rope#hasSchedulePart> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf bag:hasItem ;
                                            owl:inverseOf <https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule> ;
                                            rdf:type owl:InverseFunctionalProperty ;
                                            rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                            rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#SchedulePart> ;
                                            rdfs:comment "Inverse functional property."@en ;
                                            rdfs:label "has schedule part" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasServiceType
<https://cdm.ovh/rsm/operations/rope/rope#hasServiceType> rdf:type owl:ObjectProperty ;
                                           rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#ServiceType> ;
                                           rdfs:label "has service type"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess
<https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess> rdf:type owl:ObjectProperty ;
                                          rdfs:subPropertyOf dul:hasPart ;
                                          rdfs:domain dul:Process ;
                                          rdfs:range dul:Process ;
                                          rdfs:label "has sub process"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasTemporalRole
<https://cdm.ovh/rsm/operations/rope/rope#hasTemporalRole> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                            rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#TemporalRole> ;
                                            rdfs:label "has temporal role"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasTrainRunState
<https://cdm.ovh/rsm/operations/rope/rope#hasTrainRunState> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun> ;
                                             rdf:type owl:InverseFunctionalProperty ;
                                             rdfs:label "has train run state" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasTrainState
<https://cdm.ovh/rsm/operations/rope/rope#hasTrainState> rdf:type owl:ObjectProperty ,
                                                   owl:InverseFunctionalProperty ;
                                          rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Train> ;
                                          rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                          rdfs:label "has train state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule
<https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule> rdf:type owl:ObjectProperty ;
                                              rdfs:label "in journey schedule"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun
<https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf dul:isSettingFor ;
                                              rdf:type owl:FunctionalProperty ;
                                              rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRunState> ;
                                              rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                              rdfs:label "is state of train run" .


###  https://cdm.ovh/rsm/operations/rope/rope#nextDescriptionVersion
<https://cdm.ovh/rsm/operations/rope/rope#nextDescriptionVersion> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion> ;
                                                   rdf:type owl:FunctionalProperty ,
                                                            owl:InverseFunctionalProperty ;
                                                   rdfs:label "next description version" .


###  https://cdm.ovh/rsm/operations/rope/rope#nextSection
<https://cdm.ovh/rsm/operations/rope/rope#nextSection> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf list:nextItem ;
                                        rdf:type owl:FunctionalProperty ,
                                                 owl:InverseFunctionalProperty ;
                                        rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySection> ;
                                        rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#JourneySection> ;
                                        rdfs:label "next section"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#playsFacilityRole
<https://cdm.ovh/rsm/operations/rope/rope#playsFacilityRole> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf dul:playsRole ;
                                              rdfs:domain rope:Facility ;
                                              rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction> ;
                                              rdfs:label "plays facility role"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#playsOperationalRole
<https://cdm.ovh/rsm/operations/rope/rope#playsOperationalRole> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf dul:playsRole ;
                                                 rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder> ;
                                                 rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationalRole> ;
                                                 rdfs:comment "property listing the possible roles, not those actually played on a particular train run"@en ;
                                                 rdfs:label "plays operational role"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion
<https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion> rdf:type owl:ObjectProperty ;
                                                       rdfs:subPropertyOf prov:wasRevisionOf ,
                                                                          <https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion> ;
                                                       rdf:type owl:FunctionalProperty ,
                                                                owl:InverseFunctionalProperty ;
                                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                                       rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                                       rdfs:comment "A transitive property linking a new description to the (sole) previous one it revises. \"Supersedes\" would be a ternary relation, the value of which could be deducted from the \"effective from\" datetimes, and the datetime of the query: not conceptualized in this ontology."@en ;
                                                       rdfs:label "previous description version" .


###  https://cdm.ovh/rsm/operations/rope/rope#previousSection
<https://cdm.ovh/rsm/operations/rope/rope#previousSection> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf list:previousItem ;
                                            rdf:type owl:FunctionalProperty ,
                                                     owl:InverseFunctionalProperty ;
                                            rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySection> ;
                                            rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#JourneySection> ;
                                            rdfs:label "previous section"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#realizesPlannedJourneyOrPath
<https://cdm.ovh/rsm/operations/rope/rope#realizesPlannedJourneyOrPath> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf dul:realizes ;
                                                         rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney> ;
                                                         rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> ;
                                                         rdfs:comment "Planned journey (the object) may be a path, a planned journey (in the strict sense) or a forecast journey (an updated planned journey)"@en ;
                                                         rdfs:label "realizesPlannedJourneyOrPath"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#referenceOTN
<https://cdm.ovh/rsm/operations/rope/rope#referenceOTN> rdf:type owl:ObjectProperty ,
                                                  owl:FunctionalProperty ;
                                         rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                         rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN> ;
                                         rdfs:label "has reference OTN" .


###  https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion
<https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion> rdf:type owl:ObjectProperty ,
                                                               owl:TransitiveProperty ;
                                                      rdfs:comment "Links a description version to all previous description versions (therefore not a functional property). Transitive closure of previousDescriptionVersion."@en ;
                                                      rdfs:label "revises description version" .


###  https://cdm.ovh/rsm/operations/rope/rope#trainLeadRU
<https://cdm.ovh/rsm/operations/rope/rope#trainLeadRU> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf dul:hasParticipant ;
                                        rdf:type owl:FunctionalProperty ;
                                        rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                        rdfs:range <https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder> ;
                                        rdfs:comment "Points to the \"lead RU\" for the entire train"@en ;
                                        rdfs:label "train lead RU"@en ;
                                        rdfs:seeAlso "http://data.europa.eu/949/TrainOperatingRU"^^xsd:anyURI .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2006/time#inXSDDateTimeStamp
time:inXSDDateTimeStamp rdf:type owl:DatatypeProperty ;
                        rdfs:domain time:Instant ;
                        rdfs:range xsd:dateTimeStamp .


###  http://www.w3.org/ns/org#identifier
org:identifier rdf:type owl:DatatypeProperty ;
               rdfs:domain org:Organization ;
               rdfs:range rdfs:Literal ;
               rdfs:comment """range = rdfs:Literal (not an OWL class) = any number or string.
Note: org:identifier is a simplistic way to identify companies; the identifier may be context-specific so they are no longer direct properties is more refined ontologies."""@en ;
               rdfs:label "identifier"@en .


###  http://www.w3.org/ns/prov#generatedAtTime
prov:generatedAtTime rdf:type owl:DatatypeProperty ;
                     rdfs:domain prov:Entity .


###  http://www.w3.org/ns/prov#invalidatedAtTime
prov:invalidatedAtTime rdf:type owl:DatatypeProperty .


###  https://cdm.ovh/rsm/operations/rope/rope#hasPrimaryCode
rope:hasPrimaryCode rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain rope:OperationalLocation ;
                    rdfs:range xsd:string ;
                    rdfs:label "has primary code"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasSubsidiaryCode
rope:hasSubsidiaryCode rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain rope:OperationalLocation ;
                       rdfs:range xsd:string ;
                       rdfs:label "has subsidiary code"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#locationName
rope:locationName rdf:type owl:DatatypeProperty ;
                  rdfs:domain rope:OperationalLocation ;
                  rdfs:range xsd:string ;
                  rdfs:label "location name"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#asPNG
<https://cdm.ovh/rsm/operations/rope/rope#asPNG> rdf:type owl:DatatypeProperty ,
                                           owl:FunctionalProperty ;
                                  rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#ContentLocation> ;
                                  rdfs:range xsd:base64Binary ;
                                  rdfs:label "as PNG"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#asWKT
<https://cdm.ovh/rsm/operations/rope/rope#asWKT> rdf:type owl:DatatypeProperty ,
                                           owl:FunctionalProperty ;
                                  rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState> ;
                                  rdfs:range xsd:string ;
                                  rdfs:comment "single string, using WKT serialization"@en ;
                                  rdfs:label "as wkt" .


###  https://cdm.ovh/rsm/operations/rope/rope#compositionValidationPassed
<https://cdm.ovh/rsm/operations/rope/rope#compositionValidationPassed> rdf:type owl:DatatypeProperty ,
                                                                 owl:FunctionalProperty ;
                                                        rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState> ;
                                                        rdfs:range xsd:boolean ;
                                                        rdfs:label "composition validation passed" .


###  https://cdm.ovh/rsm/operations/rope/rope#createdAt
<https://cdm.ovh/rsm/operations/rope/rope#createdAt> rdf:type owl:DatatypeProperty ;
                                      rdfs:subPropertyOf prov:generatedAtTime ;
                                      rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                      rdfs:range xsd:dateTimeStamp ;
                                      rdfs:comment "like other time properties, it is not made functional, to allow multiple time representations (time zones)."@en ;
                                      rdfs:label "created at"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#effectiveFrom
<https://cdm.ovh/rsm/operations/rope/rope#effectiveFrom> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                          rdfs:range xsd:dateTimeStamp ;
                                          rdfs:label "effective from"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#effectiveUntil
<https://cdm.ovh/rsm/operations/rope/rope#effectiveUntil> rdf:type owl:DatatypeProperty ;
                                           rdfs:subPropertyOf prov:invalidatedAtTime ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                           rdfs:range xsd:dateTimeStamp ;
                                           rdfs:comment "Value can be computed by looking up updates and their \"effective from\" datetimes, supposing the newer versions invalidate earlier ones at the time they become effective. The ontology does not go that far (it would be a matter of SWRL rules)."@en ;
                                           rdfs:label "effective until"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasBICCcode
<https://cdm.ovh/rsm/operations/rope/rope#hasBICCcode> rdf:type owl:DatatypeProperty ,
                                                 owl:FunctionalProperty ;
                                        rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "BIC code according to ISO 6346 (4 letters, 6 numeric digits and 1 check digit)"@en ;
                                        rdfs:label "has BIC code" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasComment
<https://cdm.ovh/rsm/operations/rope/rope#hasComment> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Message> ;
                                       rdfs:range xsd:string ;
                                       rdfs:label "has comment"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasDesignation
<https://cdm.ovh/rsm/operations/rope/rope#hasDesignation> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain rope:Track ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "Designation: to be discussed. Probably not unique. Can have short or long forms (e.g. \"Track 5\"  in the context of some yard; \"Alnabru yard track 5\" in a larger context)."@en ;
                                           rdfs:label "has designation"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasFullText
<https://cdm.ovh/rsm/operations/rope/rope#hasFullText> rdf:type owl:DatatypeProperty ,
                                                 owl:FunctionalProperty ;
                                        rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Message> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "typically, the full XML or JSON snippet (including comments, if any)"@en ;
                                        rdfs:label "has full text" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasILUcode
<https://cdm.ovh/rsm/operations/rope/rope#hasILUcode> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                       rdfs:range xsd:string ;
                                       rdfs:comment "ILU code (under EN 13044 series) is the standardized identification (owner, number, check digit) for intermodal loading units in Europe. The ILU code is designed for non-ISO containers, swap bodies, semi-trailers in intra-European combined transport."@en ;
                                       rdfs:label "has ILU code"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasKemlerCode
<https://cdm.ovh/rsm/operations/rope/rope#hasKemlerCode> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain [ rdf:type owl:Class ;
                                                        owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                      <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                    )
                                                      ] ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment "Emergency response-related code (3 digits) as per RID 5.3.2.3"@en ;
                                          rdfs:label "has Kemler code" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasLengthInMeters
<https://cdm.ovh/rsm/operations/rope/rope#hasLengthInMeters> rdf:type owl:DatatypeProperty ,
                                                       owl:FunctionalProperty ;
                                              rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState> ;
                                              rdfs:range xsd:decimal ;
                                              rdfs:label "has length in meters"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasMassInTons
<https://cdm.ovh/rsm/operations/rope/rope#hasMassInTons> rdf:type owl:DatatypeProperty ,
                                                   owl:FunctionalProperty ;
                                          rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainMassState> ;
                                          rdfs:range xsd:decimal ;
                                          rdfs:comment "provisional. To be expanded, using SSN and QUDT."@en ;
                                          rdfs:label "has mass in tons"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasOtherCode
<https://cdm.ovh/rsm/operations/rope/rope#hasOtherCode> rdf:type owl:DatatypeProperty ;
                                         rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                         rdfs:range xsd:string ;
                                         rdfs:label "has other code"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasRFIDIdentifier
<https://cdm.ovh/rsm/operations/rope/rope#hasRFIDIdentifier> rdf:type owl:DatatypeProperty ,
                                                       owl:FunctionalProperty ;
                                              rdfs:domain [ rdf:type owl:Class ;
                                                            owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                          <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                        )
                                                          ] ;
                                              rdfs:range xsd:string ;
                                              rdfs:label "has RFID identifier"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#hasRID_UN_Number
<https://cdm.ovh/rsm/operations/rope/rope#hasRID_UN_Number> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain [ rdf:type owl:Class ;
                                                           owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                         <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                       )
                                                         ] ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "RID chapter 3.2 Table A column 1. Identifies the dangerous substance. Number to be affixed to wagon or ITU according to RID chapter 5."@en ;
                                             rdfs:label "has RID UN number" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasRID_class
<https://cdm.ovh/rsm/operations/rope/rope#hasRID_class> rdf:type owl:DatatypeProperty ;
                                         rdfs:domain [ rdf:type owl:Class ;
                                                       owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                     <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                   )
                                                     ] ;
                                         rdfs:range xsd:string ;
                                         rdfs:comment "RID chapter 3.2 Table A column 3a. Identifies the hazard type. Class code to be affixed to wagon or ITU according to RID chapter 5."@en ;
                                         rdfs:label "has RID class" .


###  https://cdm.ovh/rsm/operations/rope/rope#hasSpeed
<https://cdm.ovh/rsm/operations/rope/rope#hasSpeed> rdf:type owl:DatatypeProperty ,
                                              owl:FunctionalProperty ;
                                     rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainSpeedState> ;
                                     rdfs:range xsd:decimal ;
                                     rdfs:comment "current speed, in km/h"@en ;
                                     rdfs:label "has speed"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#isStationary
<https://cdm.ovh/rsm/operations/rope/rope#isStationary> rdf:type owl:DatatypeProperty ,
                                                  owl:FunctionalProperty ;
                                         rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState> ;
                                         rdfs:range xsd:boolean ;
                                         rdfs:label "is stationary"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#issuedAt
<https://cdm.ovh/rsm/operations/rope/rope#issuedAt> rdf:type owl:DatatypeProperty ,
                                              owl:FunctionalProperty ;
                                     rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationalTime> ;
                                     rdfs:range xsd:dateTimeStamp ;
                                     rdfs:comment "Timestamp when the forecast value (most common case) or any other time value was generated or last updated"@en ;
                                     rdfs:label "issued at" .


###  https://cdm.ovh/rsm/operations/rope/rope#messageID
<https://cdm.ovh/rsm/operations/rope/rope#messageID> rdf:type owl:DatatypeProperty ,
                                               owl:FunctionalProperty ;
                                      rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                      rdfs:range xsd:string ;
                                      rdfs:label "message ID"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#messageVersion
<https://cdm.ovh/rsm/operations/rope/rope#messageVersion> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                           rdfs:range xsd:string ;
                                           rdfs:label "message version"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#name
<https://cdm.ovh/rsm/operations/rope/rope#name> rdf:type owl:DatatypeProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                 rdfs:range xsd:string ;
                                 rdfs:label "name"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#reportedAt
<https://cdm.ovh/rsm/operations/rope/rope#reportedAt> rdf:type owl:DatatypeProperty ;
                                       rdfs:subPropertyOf prov:generatedAtTime ;
                                       rdf:type owl:FunctionalProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Message> ;
                                       rdfs:range xsd:dateTimeStamp ;
                                       rdfs:comment "same semantics as prov:generatedAtTime"@en ;
                                       rdfs:label "reported at"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#reportedBy
<https://cdm.ovh/rsm/operations/rope/rope#reportedBy> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                       rdfs:range xsd:string ;
                                       rdfs:comment ""@en ;
                                       rdfs:label "reported by"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#sizeAndTypeCode
<https://cdm.ovh/rsm/operations/rope/rope#sizeAndTypeCode> rdf:type owl:DatatypeProperty ,
                                                     owl:FunctionalProperty ;
                                            rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Container> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "4 digit alphanum code for container size and type, according to ISO 6346"@en ;
                                            rdfs:label "size and type code" .


###  https://cdm.ovh/rsm/operations/rope/rope#startsAtOrigin
<https://cdm.ovh/rsm/operations/rope/rope#startsAtOrigin> rdf:type owl:DatatypeProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                           rdfs:range xsd:boolean ;
                                           rdfs:comment "if False: means pass-through"@en ;
                                           rdfs:label "starts at origin"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#stopsAtDestination
<https://cdm.ovh/rsm/operations/rope/rope#stopsAtDestination> rdf:type owl:DatatypeProperty ,
                                                        owl:FunctionalProperty ;
                                               rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ;
                                               rdfs:range xsd:boolean ;
                                               rdfs:comment "if False: means pass-through"@en ;
                                               rdfs:label "stops at destination"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#trainDepartureDate
<https://cdm.ovh/rsm/operations/rope/rope#trainDepartureDate> rdf:type owl:DatatypeProperty ,
                                                        owl:FunctionalProperty ;
                                               rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#TrainRun> ;
                                               rdfs:range xsd:date ;
                                               rdfs:comment "Target datatype, xsd:date, is not part of OWL2 and may be incompatible with some reasoners. Pellet is fine, while HermiT (which adheres more strictly to OWL2 conventions) may complain."@en ,
                                                            "The planned departure date that defines the train run. Remains unchanged even if the revised or actual departure is past midnight, hence on the next day."@en ;
                                               rdfs:label "train departure date"@en ;
                                               rdfs:seeAlso <http://data.europa.eu/949/TrainDepartureDate> .


###  https://cdm.ovh/rsm/operations/rope/rope#uicWagonNumber
<https://cdm.ovh/rsm/operations/rope/rope#uicWagonNumber> rdf:type owl:DatatypeProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://cdm.ovh/rsm/operations/rope/rope#Wagon> ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "may it vary in a wagon's lifetime? if not, consider moving to rolling stock ontology."@en ;
                                           rdfs:label "uic wagon number"@en .


#################################################################
#    Classes
#################################################################

###  http://cdm.ovh/rsm/rolling_stock/typology/typology#RollingStock
<http://cdm.ovh/rsm/rolling_stock/typology/typology#RollingStock> rdf:type owl:Class .


###  http://cdm.ovh/rsm/rolling_stock/typology/typology#Wagon
<http://cdm.ovh/rsm/rolling_stock/typology/typology#Wagon> rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/cp/owl/list.owl#List
list:List rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/cp/owl/list.owl#ListItem
list:ListItem rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description
dul:Description rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact
dul:DesignedArtifact rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event
dul:Event rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject
dul:InformationObject rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Organization
dul:Organization rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Place
dul:Place rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Plan
dul:Plan rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process
dul:Process rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Role
dul:Role rdf:type owl:Class ;
         rdfs:comment "Note: aligning with DOLCE, roles are defined as individuals such as \"freight role\" (instance of Load role), with no properties attached."@en .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation
dul:Situation rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval
dul:TimeInterval rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


###  http://www.w3.org/2006/time#Instant
time:Instant rdf:type owl:Class ;
             rdfs:label "time:Instant"@en .


###  http://www.w3.org/2006/time#Interval
time:Interval rdf:type owl:Class ;
              rdfs:comment "W3C Time interval, possibly open-ended or degenerate (start = end)"@en .


###  http://www.w3.org/ns/org#Organization
org:Organization rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class .


###  http://www.w3.org/ns/regorg#RegisteredOrganization
regorg:RegisteredOrganization rdf:type owl:Class ;
                              rdfs:subClassOf org:Organization .


###  https://cdm.ovh/rsm/network/netw#NetEntity
<https://cdm.ovh/rsm/network/netw#NetEntity> rdf:type owl:Class .


###  https://cdm.ovh/rsm/operations/rope/rope#Circulation
rope:Circulation rdf:type owl:Class ;
                 rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dul:hasTimeInterval ;
                                   owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval>
                                 ] ;
                 rdfs:label "Train process"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Facility
rope:Facility rdf:type owl:Class ;
              rdfs:subClassOf <https://cdm.ovh/rsm/network/netw#NetEntity> ,
                              <https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact> ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty rope:atOperationalLocation ;
                                owl:allValuesFrom rope:OperationalLocation
                              ] ;
              rdfs:comment "Class for facilities pertaining to operations, e.g. a maintenance shop, a yard, a train washing machine..."@en ;
              rdfs:label "Facility"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Load
rope:Load rdf:type owl:Class ;
          rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact> ;
          rdfs:label "Load"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation
rope:OperationalLocation rdf:type owl:Class ;
                         rdfs:subClassOf dul:Place ,
                                         <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                         rdfs:comment "TAF TSI ontology: identifies a Location using a LocationIdent"@en ;
                         rdfs:label "Operational location"@en ;
                         rdfs:seeAlso "http://data.europa.eu/949/Location"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#ShuntingMovement
rope:ShuntingMovement rdf:type owl:Class ;
                      rdfs:subClassOf rope:Circulation ;
                      rdfs:label "Shunting movement"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Track
rope:Track rdf:type owl:Class ;
           rdfs:subClassOf <https://cdm.ovh/rsm/network/netw#NetEntity> ,
                           <https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact> ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty rope:atOperationalLocation ;
                             owl:allValuesFrom rope:OperationalLocation
                           ] ;
           rdfs:comment "Note: atOperationalLocation is provided by superclass OperationalArtifact"@en ,
                        "Track in the operational sense, i.e. a stretch of track, usually continuous, that is individuated in operating (driving, shunting) instructions."@en ;
           rdfs:label "Track"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#AdministrativeState
<https://cdm.ovh/rsm/operations/rope/rope#AdministrativeState> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                                rdfs:label "Administrative state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#CarrierState
<https://cdm.ovh/rsm/operations/rope/rope#CarrierState> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ;
                                         rdfs:label "Carrier state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Container
<https://cdm.ovh/rsm/operations/rope/rope#Container> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                      rdfs:label "Container"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#ContentLocation
<https://cdm.ovh/rsm/operations/rope/rope#ContentLocation> rdf:type owl:Class ;
                                            rdfs:comment "The image file as a BLOB. Possibly not in the same namespace as the Image individual."@en ;
                                            rdfs:label "Content location" .


###  https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus
<https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus> rdf:type owl:Class ;
                                          rdfs:label "Customs status"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney
<https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney> rdf:type owl:Class ;
                                            rdfs:subClassOf dul:Process ,
                                                            <https://cdm.ovh/rsm/operations/rope/rope#Journey> ;
                                            owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> ;
                                            rdfs:label "Executed journey"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction
<https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction> rdf:type owl:Class ;
                                                   rdfs:subClassOf skos:Concept ;
                                                   rdfs:comment "Constructed as the subset of all skos Concepts that are inScheme \"Facility role or function scheme\"."@en ,
                                                                "We assume functions to be permanent capabilities (by design), roles to be occasional capabilities (used in some situations), keeping those capabilities in a single terminology."@en ;
                                                   rdfs:label "Facility role or function" .


###  https://cdm.ovh/rsm/operations/rope/rope#FreightRole
<https://cdm.ovh/rsm/operations/rope/rope#FreightRole> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#LoadRole> ;
                                        owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#PassengerRole> ;
                                        rdfs:label "Freight role" .


###  https://cdm.ovh/rsm/operations/rope/rope#ITU
<https://cdm.ovh/rsm/operations/rope/rope#ITU> rdf:type owl:Class ;
                                rdfs:subClassOf rope:Load ;
                                owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#Wagon> ;
                                rdfs:label "Intermodal Transport Unit"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Image
<https://cdm.ovh/rsm/operations/rope/rope#Image> rdf:type owl:Class ;
                                  rdfs:subClassOf dul:InformationObject ;
                                  rdfs:label "Image"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Journey
<https://cdm.ovh/rsm/operations/rope/rope#Journey> rdf:type owl:Class ;
                                    rdfs:label "Journey"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule
<https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> rdf:type owl:Class ;
                                            rdfs:subClassOf list:List ,
                                                            <https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription> ;
                                            rdfs:comment """Description that is common to paths, planned journeys, and executed journeys. It has an origin, departure time, destination, arrival time.

It consists in JourneySections, each journey section has the same structure."""@en ,
                                                         "Since journey structures are meant to be shared, their instances should not be modified once used. New instances should be minted for every change."@en ;
                                            rdfs:label "Journey schedule" .


###  https://cdm.ovh/rsm/operations/rope/rope#JourneySection
<https://cdm.ovh/rsm/operations/rope/rope#JourneySection> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule> ,
                                                           <https://cdm.ovh/rsm/operations/rope/rope#SchedulePart> ;
                                           owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#StaticSection> ;
                                           rdfs:comment "Journey sections are chained by properties nextSection and previousSection."@en ;
                                           rdfs:label "Journey section"@en ;
                                           rdfs:seeAlso "http://data.europa.eu/949/JourneySection"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#LoadRole
<https://cdm.ovh/rsm/operations/rope/rope#LoadRole> rdf:type owl:Class ;
                                     rdfs:subClassOf dul:Role ,
                                                     <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                     rdfs:label "Load role" .


###  https://cdm.ovh/rsm/operations/rope/rope#LoadState
<https://cdm.ovh/rsm/operations/rope/rope#LoadState> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty dul:hasTimeInterval ;
                                                        owl:allValuesFrom time:Interval
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty dul:isClassifiedBy ;
                                                        owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#FreightRole>
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty dul:isSettingFor ;
                                                        owl:allValuesFrom [ rdf:type owl:Class ;
                                                                            owl:unionOf ( <https://cdm.ovh/rsm/operations/rope/rope#ITU>
                                                                                          <https://cdm.ovh/rsm/operations/rope/rope#Wagon>
                                                                                        )
                                                                          ]
                                                      ] ;
                                      rdfs:label "Load state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#LocomotiveRole
<https://cdm.ovh/rsm/operations/rope/rope#LocomotiveRole> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole> ;
                                           rdfs:label "Locomotive role"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Message
<https://cdm.ovh/rsm/operations/rope/rope#Message> rdf:type owl:Class ;
                                    rdfs:subClassOf dul:InformationObject ,
                                                    prov:Entity ;
                                    rdfs:comment """Superclass for all messages exchanged in the context of the FP5 demo. Properties are from PROV-O (emitter, generation time) and full text (string, e.g. JSON snippet). The full text follows a schema not further specified here (TAF XSD or FP5-specific JSON schema, respectively).
Message payloads are mostly Operational States or VersionedDescriptions."""@en ;
                                    rdfs:label "Message"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OTN
<https://cdm.ovh/rsm/operations/rope/rope#OTN> rdf:type owl:Class ;
                                rdfs:comment "Operational Train Number. A train may bear different numbers along its course."@en ;
                                rdfs:label "OTN"@en ;
                                rdfs:seeAlso "http://data.europa.eu/949/OperationalTrainNumberIdentifier"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact
<https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact> rdf:type owl:Class ;
                                                rdfs:subClassOf dul:DesignedArtifact ,
                                                                <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                                rdfs:label "Operational artifact"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity
<https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> rdf:type owl:Class ;
                                              rdfs:comment "Abstract class for all things related to the process of operating a freight train"@en ;
                                              rdfs:label "Operational entity" .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant
<https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant> rdf:type owl:Class ;
                                               rdfs:subClassOf time:Instant ,
                                                               <https://cdm.ovh/rsm/operations/rope/rope#OperationalTime> ;
                                               owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval> ;
                                               rdfs:comment "An instant related to some operational event (planned / forecast / observed / ...)."@en ;
                                               rdfs:label "Operational instant"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval
<https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval> rdf:type owl:Class ;
                                                rdfs:subClassOf time:Interval ,
                                                                <https://cdm.ovh/rsm/operations/rope/rope#OperationalTime> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#hasBeginning> ;
                                                                  owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant>
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#hasEnd> ;
                                                                  owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant>
                                                                ] ;
                                                rdfs:comment "Time interval, as used in the context of operations. Can play various roles (actual, planned, forecast...). Implementer can choose to coerce it to proper intervals (beginning and end time are then distinct individuals with distinct dateTime values)."@en ;
                                                rdfs:label "Operational interval"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess
<https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess> rdf:type owl:Class ;
                                               rdfs:subClassOf dul:Process ,
                                                               <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                               rdfs:label "Operational process"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalRole
<https://cdm.ovh/rsm/operations/rope/rope#OperationalRole> rdf:type owl:Class ;
                                            rdfs:subClassOf dul:Role ,
                                                            <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                            rdfs:comment "played by some Organization (Legal Entity)"@en ;
                                            rdfs:label "Operational role" .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalState
<https://cdm.ovh/rsm/operations/rope/rope#OperationalState> rdf:type owl:Class ;
                                             rdfs:subClassOf dul:Situation ,
                                                             <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty dul:hasSetting ;
                                                               owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#hasParticipant> ;
                                                               owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity>
                                                             ] ;
                                             rdfs:comment "An operational state is a situation (in the sense of DUL). An operational is a typical payload of any operational message."@en ,
                                                          "Note: other states may concern yards, depots, stations... to be discussed."@en ;
                                             rdfs:label "Operational state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationalTime
<https://cdm.ovh/rsm/operations/rope/rope#OperationalTime> rdf:type owl:Class ;
                                            rdfs:subClassOf dul:TimeInterval ;
                                            rdfs:comment "Abstract superclass for time information in operations. The context in which Operational time is used tells whether this is an actual time, or a planned time, or a forecast time, etc."@en ;
                                            rdfs:label "Operational time"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder
<https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder> rdf:type owl:Class ;
                                                  rdfs:subClassOf dul:Organization ,
                                                                  regorg:RegisteredOrganization ;
                                                  rdfs:comment "Any registered organisation that is involved in the train run (operators, carriers, consignors and consignees, wagon owners...)"@en ;
                                                  rdfs:label "Operations stakeholder"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#PassengerRole
<https://cdm.ovh/rsm/operations/rope/rope#PassengerRole> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#LoadRole> ;
                                          rdfs:label "Passenger role" .


###  https://cdm.ovh/rsm/operations/rope/rope#Path
<https://cdm.ovh/rsm/operations/rope/rope#Path> rdf:type owl:Class ;
                                 rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> ;
                                 rdfs:label "Path"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#PlannedJourney
<https://cdm.ovh/rsm/operations/rope/rope#PlannedJourney> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> ;
                                           rdfs:comment "The planned journey may share the same JourneySchedule as the path, or deviate from it (e.g. deviations related to temporary speed restrictions, added or canceled stops). It may be updated after the train departure (in which case it gives rise to a forecast schedule, of a different class)."@en ;
                                           rdfs:label "Planned journey"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath
<https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath> rdf:type owl:Class ;
                                                 rdfs:subClassOf dul:Plan ,
                                                                 <https://cdm.ovh/rsm/operations/rope/rope#Journey> ;
                                                 rdfs:label "Planned journey or path"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN
<https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN> rdf:type owl:Class ;
                                         rdfs:label "Reference OTN"@en ;
                                         rdfs:seeAlso "http://data.europa.eu/949/ReferenceOTN"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#SchedulePart
<https://cdm.ovh/rsm/operations/rope/rope#SchedulePart> rdf:type owl:Class ;
                                         rdfs:subClassOf list:ListItem ;
                                         rdfs:label "Schedule part"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#ServiceType
<https://cdm.ovh/rsm/operations/rope/rope#ServiceType> rdf:type owl:Class ;
                                        rdfs:label "Service type"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#StaticSection
<https://cdm.ovh/rsm/operations/rope/rope#StaticSection> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#SchedulePart> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#atTime> ;
                                                            owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#hasIM> ;
                                                            owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder>
                                                          ] ;
                                          rdfs:comment "Journey sections \"at rest\" (but possibly implying shunting movements inside an operational location). May host maintenance or customes operations."@en ;
                                          rdfs:label "Static section"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#SwapBody
<https://cdm.ovh/rsm/operations/rope/rope#SwapBody> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                     rdfs:label "Swap body"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TafMessage
<https://cdm.ovh/rsm/operations/rope/rope#TafMessage> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#Message> ;
                                       owl:disjointWith <https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage> ;
                                       rdfs:comment "Message compliant with TAF TSI XSD"@en ;
                                       rdfs:label "TAF message"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TemporalRole
<https://cdm.ovh/rsm/operations/rope/rope#TemporalRole> rdf:type owl:Class ;
                                         rdfs:comment "Role definition for operational instants or (time) intervals. More instances can be added (e.g. \"contractual\"), but in any case the context (situation) should be expressed (planned in what document? forecast by whom?), lest the roles be purely decorative."@en ;
                                         rdfs:label "Temporal role"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole
<https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole> rdf:type owl:Class ;
                                                  rdfs:subClassOf dul:Role ,
                                                                  <https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity> ;
                                                  rdfs:comment """Can be extended to include powered car or trailer roles.
Case of hauled locomotive (fr: marchandise roulante) does not belong here, as no traction is provided.
To be differetiated from (possible, not included) traction provider role, the agent being an organization in that case."""@en ,
                                                               "played by one or more locomotives on a train run"@en ;
                                                  rdfs:label "Traction provision role" .


###  https://cdm.ovh/rsm/operations/rope/rope#Trailer
<https://cdm.ovh/rsm/operations/rope/rope#Trailer> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#ITU> ;
                                    rdfs:label "Trailer"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#Train
<https://cdm.ovh/rsm/operations/rope/rope#Train> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact> ;
                                  rdfs:comment "For want of a better class name: denotes the rolling stock (locos, wagons...) AND their supplies (possibly depleted) AND their (variable) loads, considered as a whole, i.e. whatever is moved somewhere between origin and destination in a Train run."@en ;
                                  rdfs:label "Train"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState
<https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                                  rdfs:label "Train composition state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState
<https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainRunState> ;
                                              rdfs:label "Train customs state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState
<https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                                  rdfs:label "Train GPS position state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState
<https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainRunState> ;
                                              rdfs:label "Train journey state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState
<https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                             rdfs:label "Train length state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainLocationState
<https://cdm.ovh/rsm/operations/rope/rope#TrainLocationState> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainRunState> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty rope:atOperationalLocation ;
                                                                 owl:allValuesFrom rope:OperationalLocation
                                                               ] ;
                                               rdfs:label "Train location state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainMassState
<https://cdm.ovh/rsm/operations/rope/rope#TrainMassState> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                           rdfs:comment "Laden mass, incl. supplies"@en ;
                                           rdfs:label "Train mass state"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState
<https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState> ;
                                             rdfs:label "Train motion state" .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainRun
<https://cdm.ovh/rsm/operations/rope/rope#TrainRun> rdf:type owl:Class ;
                                     rdfs:subClassOf rope:Circulation ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess> ;
                                                       owl:allValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#TrainService>
                                                     ] ;
                                     rdfs:comment """Denotes a train run (operated on a particular date), equivalent to \"Train\" in TAF TSI, not a \"timetable entry\".
It is a process and may have parts that are sub-processes."""@en ;
                                     rdfs:label "Train run" ;
                                     rdfs:seeAlso "http://data.europa.eu/949/Train"^^xsd:anyURI .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainRunState
<https://cdm.ovh/rsm/operations/rope/rope#TrainRunState> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalState> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun> ;
                                                            owl:someValuesFrom owl:Thing
                                                          ] ;
                                          rdfs:comment "Situation (State) of a train run. Several subclasses define the train run state from several points of view."@en ;
                                          rdfs:label "Train run state" .


###  https://cdm.ovh/rsm/operations/rope/rope#TrainService
<https://cdm.ovh/rsm/operations/rope/rope#TrainService> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess> ,
                                                         [ rdf:type owl:Restriction ;
