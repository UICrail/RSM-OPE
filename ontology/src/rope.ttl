[ rdf:type owl:Restriction ;
  owl:onProperty dul:hasParticipant ;
  owl:someValuesFrom <https://cdm.ovh/rsm/operations/rope/rope#Train> ;
  rdfs:subClassOf <https://cdm.ovh/rsm/operations/rope/rope#TrainState>
] .


[ rdf:type owl:Restriction ;
