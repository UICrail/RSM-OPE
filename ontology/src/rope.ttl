###  https://cdm.ovh/rsm/operations/rope/rope#UndeterminedJourney
rope:UndeterminedJourney rdf:type owl:Class ;
                         rdfs:subClassOf rope:PlannedJourneyOrPath ;
                         rdfs:comment "Undetermined journey might be the correct expression in EN-speaking areas (unregulated train seems to exist but seems to be related to dispatcher roles, hence avoided here). At SNCF, was called \" marche indeterminee (abbr. MI)\"." ;
                         rdfs:label "Undetermined journey"@en .


###  https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription
rope:VersionedDescription rdf:type owl:Class ;
                          rdfs:subClassOf dul:Description ,
                                          prov:Entity ,
                                          rope:OperationalEntity ;
                          rdfs:comment "A description (e.g. of a schedule, or other operational specs such as orders issued to drivers) that can be revised, and is effective (= applicable) from a certain datetime. The versions are chained as a simple list (nop forks, no loops)."@en ;
                          rdfs:label "Versioned description" .


