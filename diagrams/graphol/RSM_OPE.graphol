              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Description that is common to paths, planned journeys, and executed journeys. It has an origin, departure time, destination, arrival time.

It consists in JourneySections, each journey section has the same structure.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/taf/tafp5#JourneySchedule</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Since journey structures are meant to be shared, their instances should not be modified once used. New instances should be minted for every change.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
