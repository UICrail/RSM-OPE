              <object>
                <lexicalForm>Role definition for operational instants or (time) intervals. More instances can be added (e.g. "contractual"), but in any case the context (situation) should be expressed (planned in what document? forecast by whom?), lest the roles be purely decorative.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
