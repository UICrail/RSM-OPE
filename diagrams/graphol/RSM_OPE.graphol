              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Role definition for operational instants or (time) intervals. More instances can be added (e.g. "contractual"), but in any case the context (situation) should be expressed (planned in what document? forecast by whom?), lest the roles be purely decorative.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/taf/tafp5#TractionProvisionRole</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/taf/tafp5#TractionProvisionRole</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Traction provision role</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/taf/tafp5#TractionProvisionRole</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>played by one or more locomotives on a train run</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/taf/tafp5#TractionProvisionRole</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Can be extended to include powered car or trailer roles.
Case of hauled locomotive (fr: marchandise roulante) does not belong here, as no traction is provided.
To be differetiated from (possible, not included) traction provider role, the agent being an organization in that case.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
