    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#isStationary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">is stationary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#issuedAt -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#issuedAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalTime"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">Timestamp when the forecast value (most common case) or any other time value was generated or last updated</rdfs:comment>
        <rdfs:label>issued at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#locationName -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#locationName">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">location name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#messageID -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#messageID">
