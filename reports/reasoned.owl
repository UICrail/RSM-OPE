<?xml version="1.0"?>
<rdf:RDF xmlns="http://cdm.ovh/rsm/operations/rope/rope#"
     xml:base="http://cdm.ovh/rsm/operations/rope/rope"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:bag="http://www.ontologydesignpatterns.org/cp/owl/bag.owl#"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#"
     xmlns:org="http://www.w3.org/ns/org#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:list="http://www.ontologydesignpatterns.org/cp/owl/list.owl#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rope="https://cdm.ovh/rsm/operations/rope/rope#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:regorg="http://www.w3.org/ns/regorg#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:rst-cons="https://cdm.ovh/rst/cons/cons#"
     xmlns:rst-typo="https://cdm.ovh/rst/typo/typo#">
    <owl:Ontology rdf:about="http://cdm.ovh/rsm/operations/rope/rope">
        <owl:versionIRI rdf:resource="http://cdm.ovh/rsm/operations/rope/0.2/rope"/>
        <owl:imports rdf:resource="http://cdm.ovh/rst/cons/cons"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/network/netw"/>
        <dc:author>Airy Magnien, UIC</dc:author>
        <dc:contributor>Pierre Tane, UIC</dc:contributor>
        <dc:date>30 June 2026</dc:date>
        <dc:description xml:lang="en">The RSM Operations ontology is about train operations processes and their participants. It also allows to cover data exchange items (such as telematics messages) as &quot; information objects&quot; in the sense of DUL.

This ontology refers to the DUL upper ontology (DOLCE+DnS Ultralite) which is imported here. Production versions may see the DUL import axiom removed.</dc:description>
        <dc:title xml:lang="en">RSM Operations ontology</dc:title>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <rdfs:comment xml:lang="en">In the context of operations in general, and the TAF TSI in particular, &quot;weight&quot;  is often used instead of &quot;mass&quot; while the latter is correct (and units are indeed mass units, e.g. kg). In the present ontology, we only use &quot;mass&quot;  in identifiers and labels.</rdfs:comment>
        <owl:versionInfo xml:lang="en">0.1 First release as ROPE (RSM Operations)</owl:versionInfo>
        <owl:versionInfo xml:lang="en">0.2: added ontology annotations. Fixed issues in order to pass ROBOT tests</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/author -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/author"/>
    


    <!-- http://purl.org/dc/elements/1.1/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributor"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2000/01/rdf-schema#Literal -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#base64Binary -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#base64Binary"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#boolean -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#boolean"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date">
        <rdfs:comment xml:lang="en">Not part of OWL2 datatype map. Will crash HermiT, not however Pellet.</rdfs:comment>
    </rdfs:Datatype>
    


    <!-- http://www.w3.org/2001/XMLSchema#dateTimeStamp -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#decimal -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#decimal"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#string -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/bag.owl#hasItem -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/bag.owl#hasItem"/>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/list.owl#nextItem -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/list.owl#nextItem"/>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/list.owl#previousItem -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/list.owl#previousItem"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasLocation -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasLocation">
        <rdfs:comment xml:lang="en">To be understood as &quot;at some point in time&quot;. Which point (or interval) will be given by the States.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant">
        <rdfs:comment xml:lang="en">indicates participant in the process (no defined multiplicity)</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasTimeInterval -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasTimeInterval"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isLocationOf -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isLocationOf"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#playsRole -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#playsRole"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizes -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizes"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning"/>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd"/>
    


    <!-- http://www.w3.org/ns/prov#wasAttributedTo -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAttributedTo">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasRevisionOf -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasRevisionOf"/>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasLocation"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#isOperationalLocationOf"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:comment xml:lang="en">provides time-independent operational location of anything, including bit not limited toTracks or Facilities (both being NetEntities), or TrainRuns.</rdfs:comment>
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#language">at operational location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#atTime -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#atTime">
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalTime"/>
        <rdfs:label xml:lang="en">at time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#concernsTrain -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#concernsTrain">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Circulation"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Train"/>
        <rdfs:comment xml:lang="en">refers to the train (rolling stock, supplies, loads) that participates in the operational process. Normally a single one.</rdfs:comment>
        <rdfs:label xml:lang="en">concerns train</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasArrivalTime -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasArrivalTime">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant"/>
        <rdfs:label xml:lang="en">has arrival time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasBeginning -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasBeginning">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasBeginning"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">has beginning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasComposition -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasComposition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState"/>
        <rdfs:range rdf:resource="http://cdm.ovh/rsm/rolling_stock/typology/typology#RollingStock"/>
        <rdfs:label xml:lang="en">has composition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasCustomsStatus -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasCustomsStatus">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus"/>
        <rdfs:label xml:lang="en">has customs status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasDepartureTime -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasDepartureTime">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant"/>
        <rdfs:comment xml:lang="en">May have multiple values (e.g. planned, revised, forecast, actual...), hence NOT a functional property</rdfs:comment>
        <rdfs:label xml:lang="en">has departure time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasDestination -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasDestination">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:label xml:lang="en">has destination</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasEnd -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasEnd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasEnd"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">has end</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasFacilityFunction -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasFacilityFunction">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Facility"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction"/>
        <rdfs:label xml:lang="en">has facility function</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasIM -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasIM">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder"/>
        <rdfs:label xml:lang="en">has IM</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasImageContent -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasImageContent">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Image"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ContentLocation"/>
        <rdfs:label xml:lang="en">has image content</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasJourney -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasJourney">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Journey"/>
        <rdfs:comment xml:lang="en">not a functional property, as it can be expressed w.r.t. the planned journey or the executed journey (if available). User feedback welcome.</rdfs:comment>
        <rdfs:label>has journey</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasJourneySchedule -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasJourneySchedule">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Journey"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:comment xml:lang="en">Note: it may be that the same path or planned journey has multiple schedules (variants), not further characterized here, so we did not make this property functional.</rdfs:comment>
        <rdfs:label>has journey schedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOTN -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOTN">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:range rdf:resource="https://cdm.ovh/taf/tafp5#OTN"/>
        <rdfs:comment xml:lang="en">The same train run can have different Operational Train Numbers in its course, depending on the operator or network over which it is run.</rdfs:comment>
        <rdfs:label xml:lang="en">has OTN</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/hasOperationalTrainNumberIdentifier</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInstant -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInstant">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant"/>
        <rdfs:label xml:lang="en">has operational instant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInterval -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOperationalInterval">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval"/>
        <rdfs:label xml:lang="en">has operational interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOperationalLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOperationalLocation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#StaticSection"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:label xml:lang="en">has operational location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOrigin -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOrigin">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:label xml:lang="en">has origin</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasPayload -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasPayload">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:label xml:lang="en">has payload</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasPlannedJourney -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasPlannedJourney">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:label xml:lang="en">has planned journey</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasRU -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasRU">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder"/>
        <rdfs:comment xml:lang="en">RU responsible for the journey section.
The Lead RU (responsible for the train run also for the commercial aspects) is defined at train run level.</rdfs:comment>
        <rdfs:label xml:lang="en">has RU</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasReferenceObject -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasReferenceObject">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">following the data requirements, this property qualifies the message. However this may not be optimal, since Operational States &quot;know&quot; about the objects concerned, via dul:hasSetting or dul:hasParticipant.</rdfs:comment>
        <rdfs:label>has reference object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasResult -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasResult">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainServicingState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainServicingResult"/>
        <rdfs:label xml:lang="en">has result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasSchedulePart -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasSchedulePart">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/bag.owl#hasItem"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#SchedulePart"/>
        <rdfs:comment xml:lang="en">Inverse functional property.</rdfs:comment>
        <rdfs:label>has schedule part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasServiceType -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasServiceType">
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ServiceType"/>
        <rdfs:label xml:lang="en">has service type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart"/>
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
        <rdfs:label xml:lang="en">has sub process</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasTemporalRole -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasTemporalRole">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TemporalRole"/>
        <rdfs:label xml:lang="en">has temporal role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasTrainRunState -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasTrainRunState">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label>has train run state</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasTrainState -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasTrainState">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Train"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label xml:lang="en">has train state</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#inJourneySchedule">
        <rdfs:label xml:lang="en">in journey schedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#isOperationalLocationOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#isOperationalLocationOf">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isLocationOf"/>
        <rdfs:comment xml:lang="en">inverse property of atOperationalLocation.</rdfs:comment>
        <rdfs:label xml:lang="en">is operational location of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRunState"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:label>is state of train run</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#nextDescriptionVersion -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#nextDescriptionVersion">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label>next description version</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#nextSection -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#nextSection">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/list.owl#nextItem"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySection"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySection"/>
        <rdfs:label xml:lang="en">next section</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#playsFacilityRole -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#playsFacilityRole">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#playsRole"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Facility"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction"/>
        <rdfs:label xml:lang="en">plays facility role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#playsOperationalRole -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#playsOperationalRole">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#playsRole"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalRole"/>
        <rdfs:comment xml:lang="en">property listing the possible roles, not those actually played on a particular train run</rdfs:comment>
        <rdfs:label xml:lang="en">plays operational role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#previousDescriptionVersion">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasRevisionOf"/>
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:comment xml:lang="en">A transitive property linking a new description to the (sole) previous one it revises. &quot;Supersedes&quot; would be a ternary relation, the value of which could be deducted from the &quot;effective from&quot; datetimes, and the datetime of the query: not conceptualized in this ontology.</rdfs:comment>
        <rdfs:label>previous description version</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#previousSection -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#previousSection">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/list.owl#previousItem"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySection"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySection"/>
        <rdfs:label xml:lang="en">previous section</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#realizesPlannedJourneyOrPath -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#realizesPlannedJourneyOrPath">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizes"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:comment xml:lang="en">Planned journey (the object) may be a path, a planned journey (in the strict sense) or a forecast journey (an updated planned journey)</rdfs:comment>
        <rdfs:label xml:lang="en">realizesPlannedJourneyOrPath</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#referenceOTN -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#referenceOTN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN"/>
        <rdfs:label>has reference OTN</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#revisesDescriptionVersion">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">Links a description version to all previous description versions (therefore not a functional property). Transitive closure of previousDescriptionVersion.</rdfs:comment>
        <rdfs:label>revises description version</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#trainLeadRU -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#trainLeadRU">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder"/>
        <rdfs:comment xml:lang="en">Points to the &quot;lead RU&quot; for the entire train</rdfs:comment>
        <rdfs:label xml:lang="en">train lead RU</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/TrainOperatingRU</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/taf/tafp5#hasParticipant -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/taf/tafp5#hasParticipant">
        <rdfs:label xml:lang="en">has participant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2006/time#inXSDDateTimeStamp -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDateTimeStamp">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/org#identifier -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/org#identifier">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">range = rdfs:Literal (not an OWL class) = any number or string.
Note: org:identifier is a simplistic way to identify companies; the identifier may be context-specific so they are no longer direct properties is more refined ontologies.</rdfs:comment>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/prov#generatedAtTime -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#generatedAtTime">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/prov#invalidatedAtTime -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#invalidatedAtTime"/>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#asPNG -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#asPNG">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ContentLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#base64Binary"/>
        <rdfs:label xml:lang="en">as PNG</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#asWKT -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#asWKT">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">single string, using WKT serialization</rdfs:comment>
        <rdfs:label>as wkt</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#compositionValidationPassed -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#compositionValidationPassed">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>composition validation passed</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#createdAt -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#createdAt">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#generatedAtTime"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">like other time properties, it is not made functional, to allow multiple time representations (time zones).</rdfs:comment>
        <rdfs:label xml:lang="en">created at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#effectiveFrom -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#effectiveFrom">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:label xml:lang="en">effective from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#effectiveUntil -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#effectiveUntil">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#invalidatedAtTime"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">Value can be computed by looking up updates and their &quot;effective from&quot; datetimes, supposing the newer versions invalidate earlier ones at the time they become effective. The ontology does not go that far (it would be a matter of SWRL rules).</rdfs:comment>
        <rdfs:label xml:lang="en">effective until</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasBICCcode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasBICCcode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">BIC code according to ISO 6346 (4 letters, 6 numeric digits and 1 check digit)</rdfs:comment>
        <rdfs:label>has BIC code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasComment -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasComment">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Message"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has comment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasDesignation -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasDesignation">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Track"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Designation: to be discussed. Probably not unique. Can have short or long forms (e.g. &quot;Track 5&quot;  in the context of some yard; &quot;Alnabru yard track 5&quot; in a larger context).</rdfs:comment>
        <rdfs:label xml:lang="en">has designation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasFullText -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasFullText">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Message"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">typically, the full XML or JSON snippet (including comments, if any)</rdfs:comment>
        <rdfs:label>has full text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasILUcode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasILUcode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">ILU code (under EN 13044 series) is the standardized identification (owner, number, check digit) for intermodal loading units in Europe. The ILU code is designed for non-ISO containers, swap bodies, semi-trailers in intra-European combined transport.</rdfs:comment>
        <rdfs:label xml:lang="en">has ILU code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasKemlerCode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasKemlerCode">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Emergency response-related code (3 digits) as per RID 5.3.2.3</rdfs:comment>
        <rdfs:label>has Kemler code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasLengthInMeters -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasLengthInMeters">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has length in meters</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasMassInTons -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasMassInTons">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainMassState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">provisional. To be expanded, using SSN and QUDT.</rdfs:comment>
        <rdfs:label xml:lang="en">has mass in tons</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasOtherCode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasOtherCode">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has other code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasPrimaryCode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasPrimaryCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has primary code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasRFIDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasRFIDIdentifier">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has RFID identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasRID_UN_Number -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasRID_UN_Number">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">RID chapter 3.2 Table A column 1. Identifies the dangerous substance. Number to be affixed to wagon or ITU according to RID chapter 5.</rdfs:comment>
        <rdfs:label>has RID UN number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasRID_class -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasRID_class">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">RID chapter 3.2 Table A column 3a. Identifies the hazard type. Class code to be affixed to wagon or ITU according to RID chapter 5.</rdfs:comment>
        <rdfs:label>has RID class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasSpeed -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasSpeed">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainSpeedState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">current speed, in km/h</rdfs:comment>
        <rdfs:label xml:lang="en">has speed</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#hasSubsidiaryCode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#hasSubsidiaryCode">
