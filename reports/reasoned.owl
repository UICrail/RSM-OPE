        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/network/netw#TopologyGraph -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/network/netw#TopologyGraph">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#AdministrativeState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#AdministrativeState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:label xml:lang="en">Administrative state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#CarrierState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#CarrierState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:label xml:lang="en">Carrier state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Circulation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Circulation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasTimeInterval"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Most general class for processes involving running stock running on tracks.</rdfs:comment>
        <rdfs:label xml:lang="en">Circulation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Container -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Container">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:label xml:lang="en">Container</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ContentLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ContentLocation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">The image file as a BLOB. Possibly not in the same namespace as the Image individual.</rdfs:comment>
        <rdfs:label>Content location</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#CustomsStatus">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:label xml:lang="en">Customs status</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ExecutedJourney">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Journey"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:label xml:lang="en">Executed journey</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Facility -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Facility">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntity"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Class for facilities pertaining to operations, e.g. a maintenance shop, a yard, a train washing machine...</rdfs:comment>
        <rdfs:label xml:lang="en">Facility</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#FacilityRoleOrFunction">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Constructed as the subset of all skos Concepts that are inScheme &quot;Facility role or function scheme&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">We assume functions to be permanent capabilities (by design), roles to be occasional capabilities (used in some situations), keeping those capabilities in a single terminology.</rdfs:comment>
        <rdfs:label>Facility role or function</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#FreightRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#FreightRole">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#LoadRole"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PassengerRole"/>
        <rdfs:label>Freight role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ITU -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Load"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
        <rdfs:label xml:lang="en">Intermodal Transport Unit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Image -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Image">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
        <rdfs:label xml:lang="en">Image</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Journey -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Journey">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:label xml:lang="en">Journey</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/list.owl#List"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription"/>
        <rdfs:comment xml:lang="en">Description that is common to paths, planned journeys, and executed journeys. It has an origin, departure time, destination, arrival time.

It consists in JourneySections, each journey section has the same structure.</rdfs:comment>
        <rdfs:comment xml:lang="en">Since journey structures are meant to be shared, their instances should not be modified once used. New instances should be minted for every change.</rdfs:comment>
        <rdfs:label>Journey schedule</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#JourneySection -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#JourneySection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#SchedulePart"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#StaticSection"/>
        <rdfs:comment xml:lang="en">Journey sections are chained by properties nextSection and previousSection.</rdfs:comment>
        <rdfs:label xml:lang="en">Journey section</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/JourneySection</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Load -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Load">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact"/>
        <rdfs:label xml:lang="en">Load</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#LoadRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#LoadRole">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Role"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:label>Load role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#LoadState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#LoadState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasTimeInterval"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#FreightRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
                            <rdf:Description rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Load state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#LocomotiveRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#LocomotiveRole">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole"/>
        <rdfs:label xml:lang="en">Locomotive role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Message -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Message">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Superclass for all messages exchanged in the context of the FP5 demo. Properties are from PROV-O (emitter, generation time) and full text (string, e.g. JSON snippet). The full text follows a schema not further specified here (TAF XSD or FP5-specific JSON schema, respectively).
Message payloads are mostly Operational States or VersionedDescriptions.</rdfs:comment>
        <rdfs:label xml:lang="en">Message</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:label xml:lang="en">Operational artifact</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">Abstract class for all things related to the process of operating a freight train; the disjoint union of all subclasses.</rdfs:comment>
        <rdfs:label>Operational entity</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalTime"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval"/>
        <rdfs:comment xml:lang="en">An instant related to some operational event (planned / forecast / observed / ...).</rdfs:comment>
        <rdfs:label xml:lang="en">Operational instant</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#hasBeginning"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#hasEnd"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInstant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Time interval, as used in the context of operations. Can play various roles (actual, planned, forecast...). Implementer can choose to coerce it to proper intervals (beginning and end time are then distinct individuals with distinct dateTime values).</rdfs:comment>
        <rdfs:comment xml:lang="en">consider linking with W3C time and/or RSM time</rdfs:comment>
        <rdfs:label xml:lang="en">Operational interval</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Place"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:comment xml:lang="en">TAF TSI ontology: identifies a Location using a LocationIdent</rdfs:comment>
        <rdfs:label xml:lang="en">Operational location</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/Location</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:label xml:lang="en">Operational process</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalRole">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Role"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:comment xml:lang="en">played by some Organization (Legal Entity)</rdfs:comment>
        <rdfs:label>Operational role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalState">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/taf/tafp5#hasParticipant"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An operational state is a situation (in the sense of DUL). An operational is a typical payload of any operational message.</rdfs:comment>
        <rdfs:comment xml:lang="en">Note: other states may concern yards, depots, stations... to be discussed.</rdfs:comment>
        <rdfs:label xml:lang="en">Operational state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationalTime -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationalTime">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
        <rdfs:comment xml:lang="en">Abstract superclass for time information in operations. The context in which Operational time is used tells whether this is an actual time, or a planned time, or a forecast time, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Operational time</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Organization"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/regorg#RegisteredOrganization"/>
        <rdfs:comment xml:lang="en">Any registered organisation that is involved in the train run (operators, carriers, consignors and consignees, wagon owners...)</rdfs:comment>
        <rdfs:label xml:lang="en">Operations stakeholder</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#PassengerRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#PassengerRole">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#LoadRole"/>
        <rdfs:label>Passenger role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Path -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Path">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:label xml:lang="en">Path</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#PlannedJourney -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourney">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:comment xml:lang="en">The planned journey may share the same JourneySchedule as the path, or deviate from it (e.g. deviations related to temporary speed restrictions, added or canceled stops). It may be updated after the train departure (in which case it gives rise to a forecast schedule, of a different class).</rdfs:comment>
        <rdfs:label xml:lang="en">Planned journey</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Plan"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Journey"/>
        <rdfs:label xml:lang="en">Planned journey or path</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ReferenceOTN">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:label xml:lang="en">Reference OTN</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/ReferenceOTN</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#SchedulePart -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#SchedulePart">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/list.owl#ListItem"/>
        <rdfs:label xml:lang="en">Schedule part</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ServiceType -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ServiceType">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:label xml:lang="en">Service type</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#ShuntingMovement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#ShuntingMovement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Circulation"/>
        <rdfs:label xml:lang="en">Shunting movement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#StaticSection -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#StaticSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#SchedulePart"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#atTime"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#hasIM"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationsStakeholder"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Journey sections &quot;at rest&quot; (but possibly implying shunting movements inside an operational location). May host maintenance or customes operations.</rdfs:comment>
        <rdfs:label xml:lang="en">Static section</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#SwapBody -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#SwapBody">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:label xml:lang="en">Swap body</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TafMessage -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TafMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Message"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:comment xml:lang="en">Message compliant with TAF TSI XSD</rdfs:comment>
        <rdfs:label xml:lang="en">TAF message</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TemporalRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TemporalRole">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">Role definition for operational instants or (time) intervals. More instances can be added (e.g. &quot;contractual&quot;), but in any case the context (situation) should be expressed (planned in what document? forecast by whom?), lest the roles be purely decorative.</rdfs:comment>
        <rdfs:label xml:lang="en">Temporal role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Track -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Track">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntity"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Note: atOperationalLocation is provided by superclass OperationalArtifact</rdfs:comment>
        <rdfs:comment xml:lang="en">Track in the operational sense, i.e. a stretch of track, usually continuous, that is individuated in operating (driving, shunting) instructions.</rdfs:comment>
        <rdfs:label xml:lang="en">Track</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TractionProvisionRole">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Role"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:comment xml:lang="en">Can be extended to include powered car or trailer roles.
Case of hauled locomotive (fr: marchandise roulante) does not belong here, as no traction is provided.
To be differetiated from (possible, not included) traction provider role, the agent being an organization in that case.</rdfs:comment>
        <rdfs:comment xml:lang="en">played by one or more locomotives on a train run</rdfs:comment>
        <rdfs:label>Traction provision role</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Trailer -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Trailer">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#ITU"/>
        <rdfs:label xml:lang="en">Trailer</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Train -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Train">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact"/>
        <rdfs:comment xml:lang="en">For want of a better class name: denotes the rolling stock (locos, wagons...) AND their supplies (possibly depleted) AND their (variable) loads, considered as a whole, i.e. whatever is moved somewhere between origin and destination in a Train run.

Not to be confused with the operational concept &quot;Train&quot; (a process), embodied here by class TrainRun.</rdfs:comment>
        <rdfs:label xml:lang="en">Train</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainCompositionState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label xml:lang="en">Train composition state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainCustomsState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRunState"/>
        <rdfs:label xml:lang="en">Train customs state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainGPSPositionState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label xml:lang="en">Train GPS position state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainJourneyState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRunState"/>
        <rdfs:label xml:lang="en">Train journey state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainLengthState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label xml:lang="en">Train length state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainLocationState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainLocationState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRunState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#atOperationalLocation"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Train location state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainMassState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainMassState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:comment xml:lang="en">Laden mass, incl. supplies</rdfs:comment>
        <rdfs:label xml:lang="en">Train mass state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainMotionState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label>Train motion state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainRun -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainRun">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Circulation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#hasSubProcess"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Denotes a train run (operated on a particular date), equivalent to &quot;Train&quot; in TAF TSI, not a &quot;timetable entry&quot;.
It is a process and may have parts that are sub-processes.</rdfs:comment>
        <rdfs:label>Train run</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/Train</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainRunState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainRunState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#isStateOfTrainRun"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Situation (State) of a train run. Several subclasses define the train run state from several points of view.</rdfs:comment>
        <rdfs:label>Train run state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainService -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainService">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#hasServiceType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">e.g. rolling stock maintenance or customs checks</rdfs:comment>
        <rdfs:label>Train servicing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainServicingResult -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainServicingResult">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">Note: might be generalized for making observations on all processes</rdfs:comment>
        <rdfs:label xml:lang="en">Train servicing result</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainServicingState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainServicingState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#StaticSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Note: other service types (customs, track assignment) rather relate to the Train run.</rdfs:comment>
        <rdfs:comment xml:lang="en">Train servicing process, e.g. maintenance, brake inspection...</rdfs:comment>
        <rdfs:label xml:lang="en">Train servicing state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainSpeedState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainSpeedState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainState"/>
        <rdfs:label xml:lang="en">Train speed state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TrainState -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TrainState">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Train"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Characterizes the state of the Train (as a physical asset), e.g. speed, mass, GPS coordinates of some particular point of the train, etc.
Since the subclasses are not disjoint, the ontology user is free to use a single individual to combine information. Ultimately, most useful combinations should give rise to dedicated subclasses, in the interest of efficient data serialization and transformation to/from document formats such as JSON or XML.</rdfs:comment>
        <rdfs:label xml:lang="en">Train state</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Message"/>
        <rdfs:comment xml:lang="en">FP5-specific messages</rdfs:comment>
        <rdfs:label xml:lang="en">Transport collaboration message</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#UndeterminedJourney -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#UndeterminedJourney">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#PlannedJourneyOrPath"/>
        <rdfs:comment>Undetermined journey might be the correct expression in EN-speaking areas (unregulated train seems to exist but seems to be related to dispatcher roles, hence avoided here). At SNCF, was called &quot; marche indeterminee (abbr. MI)&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">Undetermined journey</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#VersionedDescription">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:comment xml:lang="en">A description (e.g. of a schedule, or other operational specs such as orders issued to drivers) that can be revised, and is effective (= applicable) from a certain datetime. The versions are chained as a simple list (nop forks, no loops).</rdfs:comment>
        <rdfs:label>Versioned description</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#Wagon -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/operations/rope/rope#Wagon">
        <rdfs:subClassOf rdf:resource="http://cdm.ovh/rsm/rolling_stock/typology/typology#Wagon"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalArtifact"/>
        <rdfs:label xml:lang="en">Wagon</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Object"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentSituation -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentSituation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentTree -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentTree">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Configuration"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentTreeType -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentTreeType">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#View -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#View">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ViewSituation -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ViewSituation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/partsAndViews/pavo#ViewStatement -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/partsAndViews/pavo#ViewStatement">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#Extremity -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#Extremity">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#Formation -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#Formation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#ListedRollingStock -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#ListedRollingStock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2/list2#OWLList"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#RollingStock -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#RollingStock">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalArtifact"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#RollingStockSide -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#RollingStockSide">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rst/cons/cons#Vehicle -->

    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#Vehicle">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/taf/tafp5#OTN -->

    <owl:Class rdf:about="https://cdm.ovh/taf/tafp5#OTN">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">Operational Train Number. A train may bear different numbers along its course.</rdfs:comment>
        <rdfs:label xml:lang="en">OTN</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://data.europa.eu/949/OperationalTrainNumberIdentifier</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/list#EmptyList -->

    <rdf:Description rdf:about="https://w3id.org/list#EmptyList">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2/list2#ListNode"/>
    </rdf:Description>
    


    <!-- https://w3id.org/list#OWLList -->

    <rdf:Description rdf:about="https://w3id.org/list#OWLList">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2/list2#ListNode"/>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
