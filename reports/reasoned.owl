        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">message ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#messageVersion -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#messageVersion">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">message version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#name -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#name">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#OperationalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#reportedAt -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#reportedAt">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#generatedAtTime"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Message"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">same semantics as prov:generatedAtTime</rdfs:comment>
        <rdfs:label xml:lang="en">reported at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#reportedBy -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TransportCollaborationMessage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en"></rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#sizeAndTypeCode -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#sizeAndTypeCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Container"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">4 digit alphanum code for container size and type, according to ISO 6346</rdfs:comment>
        <rdfs:label>size and type code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#startsAtOrigin -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#startsAtOrigin">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">if False: means pass-through</rdfs:comment>
        <rdfs:label xml:lang="en">starts at origin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#stopsAtDestination -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#stopsAtDestination">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#JourneySchedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">if False: means pass-through</rdfs:comment>
        <rdfs:label xml:lang="en">stops at destination</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#trainDepartureDate -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#trainDepartureDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#TrainRun"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Target datatype, xsd:date, is not part of OWL2 and may be incompatible with some reasoners. Pellet is fine, while HermiT (which adheres more strictly to OWL2 conventions) may complain.</rdfs:comment>
        <rdfs:comment xml:lang="en">The planned departure date that defines the train run. Remains unchanged even if the revised or actual departure is past midnight, hence on the next day.</rdfs:comment>
        <rdfs:label xml:lang="en">train departure date</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://data.europa.eu/949/TrainDepartureDate"/>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/operations/rope/rope#uicWagonNumber -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/operations/rope/rope#uicWagonNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/operations/rope/rope#Wagon"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">may it vary in a wagon&apos;s lifetime? if not, consider moving to rolling stock ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">uic wagon number</rdfs:label>
    </owl:DatatypeProperty>
    


